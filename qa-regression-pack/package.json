{
  "name": "jf-regression-pack",
  "version": "1.0.0",
  "private": true,
  "description": "Post-deployment regression testing pack for the Infath Joint Funds portal (CIT)",
  "scripts": {
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "test:gate": "playwright test --grep @blocker",
    "test:smoke": "playwright test --grep @smoke",
    "seed": "node src/seed.ts",
    "test:backlog": "playwright test --config=playwright.backlog.config.ts",
    "test:backlog:list": "playwright test --config=playwright.backlog.config.ts --list",
    "test:list": "playwright test --list",
    "report": "playwright show-report",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^24.0.0",
    "dotenv": "^17.2.3",
    "typescript": "^5.9.3"
  }
}

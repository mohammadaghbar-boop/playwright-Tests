# Copy this file to .env and fill in real values. .env is gitignored — never commit
# real credentials. Used by Automation-Tests/utils/db-client.ts for DB-assertion
# fixtures (fixtures/db-fixture.ts) across the Playwright suite.
#
# The QA/CIT Postgres instance itself is network-restricted (VPC/IP allow-list) and
# unreachable directly from a normal dev machine or CI runner. db-client.ts relays
# queries through CloudBeaver instead (https://d-infath-db.azm-cit.com), which already
# has real network access to that DB — see Automation-Tests/README.md for the full
# design and its tradeoffs (shared admin identity, SELECT/UPDATE-only).

CB_BASE_URL=https://d-infath-db.azm-cit.com
CB_USERNAME=
CB_PASSWORD=
# Substring/exact match against a name in CloudBeaver's saved connections list.
CB_CONNECTION_NAME=PostgreSQL@pgm-l4v92x9095m41myg
# The actual application database on that Postgres server (the connection's own
# default catalog is the admin "postgres" DB, not this one).
CB_DATABASE=Azm_JointFunds

# Base URL for UI specs that don't hardcode an absolute URL.
BASE_URL=https://d-infath-jf-portal.azm-cit.com
BASE_API_URL=https://d-infath-jf-api.azm-cit.com

# Same CloudBeaver account as above, under the var names Automation-Tests/helpers/
# browser-auth.ts (used by jf157.spec.ts / JF-171-inheritance-classification.spec.ts) reads.
CB_ADMIN_USER=
CB_ADMIN_PASS=

# CloudBeaver service account (Automation-Tests/helpers/browser-auth.ts). CB_SVC_USER
# defaults to the well-known name in source; CB_SVC_PASS must be set here (no fallback).
CB_SVC_USER=
CB_SVC_PASS=

# Portal privileged / PD login accounts (Automation-Tests/helpers/auth.ts).
# SUPER_ADMIN_PASSWORD is REQUIRED (no in-source fallback — privileged account).
# PD is a demo account (a demo fallback is kept in source for convenience).
SUPER_ADMIN_EMAIL=
SUPER_ADMIN_PASSWORD=
PD_EMAIL=
PD_PASSWORD=

# See Automation-Tests/JF-171-SETUP.md for what these are and where to get real values —
# NEVER commit real values here, and never paste them into a shared/tracked file.
COURT_API_KEY=
SAMA_CALLBACK_KEY=
CMA_CALLBACK_KEY=

# Gateway headers — defaults exist in helpers/api-client.ts, only override if needed.
TENANT_ID=azm-tenant-12345
X_API_KEY=

# Portal login for the JF-171 UI-visibility check — defaults to the demo account.
ESTATE_MANAGER_EMAIL=demo-estate-manager@azm.sa
ESTATE_MANAGER_PASSWORD=Azm@123
